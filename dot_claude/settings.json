{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"includeGitInstructions": false,
	"permissions": {
		"defaultMode": "acceptEdits",
		"allow": [
			"Bash(jj status*)",
			"Bash(jj diff*)",
			"Bash(jj log*)",
			"Bash(jj show*)",
			"Bash(jj file show*)",
			"Bash(jj new*)",
			"Bash(jj commit*)",
			"Bash(jj desc*)",
			"Bash(jj workspace*)",
			"Bash(jj bookmark list*)",
			"Bash(jj op log*)",
			"Bash(jj root*)",
			"Bash(jj config*)",
			"Bash(jj git fetch*)",
			"Bash(jj next*)",
			"Bash(jj prev*)",
			"Bash(jq*)",
			"Bash(rg*)",
			"Bash(gh pr view*)",
			"Bash(gh pr list*)",
			"Bash(gh pr checks*)",
			"Bash(gh pr diff*)",
			"Bash(gh issue view*)",
			"Bash(gh issue list*)",
			"Bash(gh repo view*)",
			"Bash(gh run view*)",
			"Bash(gh run list*)",
			"Bash(sg*)",
			"Bash(ast-grep*)",
			"Bash(tokei*)",
			"Bash(tmux new-session:*)",
			"Bash(tmux capture-pane:*)",
			"Bash(man:*)",
			"Bash(tldr:*)",
			"WebSearch",
			"WebFetch(domain:github.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:docs.jj-vcs.dev)"
		],
		"ask": [
			"Bash(rm:*)",
			"Bash(mv:*)",
			"Bash(curl:*)",
			"Bash(jj restore:*)",
			"Bash(jj squash:*)",
			"Bash(jj rebase:*)",
			"Bash(jj resolve:*)"
		],
		"additionalDirectories": [
			"../lunar",
			"~/code/lunar"
		]
	},
	"enabledPlugins": {
		"ast-grep@ast-grep-marketplace": true,
		"typescript-lsp@claude-plugins-official": true,
		"rust-analyzer-lsp@claude-plugins-official": false,
		"gopls-lsp@claude-plugins-official": true
	},
	"effortLevel": "high"
}
