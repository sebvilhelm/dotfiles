{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"includeGitInstructions": false,
	"env": {
		"CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
		"CLAUDE_CODE_USE_BEDROCK": "1",
		"AWS_REGION": "eu-west-1",
		"AWS_PROFILE": "lw-employee-ai",
		"ANTHROPIC_DEFAULT_SONNET_MODEL": "eu.anthropic.claude-sonnet-4-6",
		"ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-8",
		"ANTHROPIC_DEFAULT_HAIKU_MODEL": "eu.anthropic.claude-haiku-4-5-20251001-v1:0"
	},
	"awsAuthRefresh": "aws sso login --profile lw-employee-ai",
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"model": "opus[1m]",
	"permissions": {
		"defaultMode": "acceptEdits",
		"allow": [
			"Bash(jj status*)",
			"Bash(jj diff*)",
			"Bash(jj log*)",
			"Bash(jj show*)",
			"Bash(jj file show*)",
			"Bash(jj new*)",
			"Bash(jj commit*)",
			"Bash(jj desc*)",
			"Bash(jj workspace*)",
			"Bash(jj bookmark list*)",
			"Bash(jj op log*)",
			"Bash(jj root*)",
			"Bash(jj config*)",
			"Bash(jj git fetch*)",
			"Bash(jj next*)",
			"Bash(jj prev*)",
			"Bash(jq*)",
			"Bash(rg*)",
			"Bash(grep*)",
			"Bash(fd*)",
			"Bash(find*)",
			"Bash(ls:*)",
			"Bash(tree:*)",
			"Bash(gh pr view*)",
			"Bash(gh pr list*)",
			"Bash(gh pr checks*)",
			"Bash(gh pr diff*)",
			"Bash(gh issue view*)",
			"Bash(gh issue list*)",
			"Bash(gh repo view*)",
			"Bash(gh run view*)",
			"Bash(gh run list*)",
			"Bash(sg*)",
			"Bash(ast-grep*)",
			"Bash(tokei*)",
			"Bash(tmux new-session:*)",
			"Bash(tmux capture-pane:*)",
			"Bash(man:*)",
			"Bash(tldr:*)",
			"Bash(go build:*)",
			"Bash(go test:*)",
			"Bash(go doc:*)",
			"WebSearch",
			"WebFetch(domain:github.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:docs.jj-vcs.dev)"
		],
		"ask": [
			"Bash(rm:*)",
			"Bash(mv:*)",
			"Bash(curl:*)",
			"Bash(jj restore:*)",
			"Bash(jj squash:*)",
			"Bash(jj rebase:*)",
			"Bash(jj resolve:*)"
		],
		"additionalDirectories": [
			"../lunar",
			"~/code/lunar"
		]
	},
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "afplay /System/Library/Sounds/Morse.aiff",
						"async": true
					}
				]
			}
		]
	},
	"enabledPlugins": {
		"ast-grep@ast-grep-marketplace": true,
		"typescript-lsp@claude-plugins-official": true,
		"rust-analyzer-lsp@claude-plugins-official": false,
		"gopls-lsp@claude-plugins-official": true
	},
	"effortLevel": "high",
	"statusLine": {
		"type": "command",
		"command": "sh ~/.claude/statusline-command.sh"
	}
}
